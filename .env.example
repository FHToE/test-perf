# Copy this file to .env (which is gitignored) and tweak values as needed.
# Shell env vars win over values from .env.

# --- required ---

# Deployed FE base URL (no trailing slash). Default points to the dev environment on Railway.
BENCH_BASE_URL=https://smi-metaverso-app-dev.up.railway.app

# Comma-separated list of STARTING room paths. Each is treated as a "lobby":
# the scenario walks lobby → portal → room A → POI → portal → room B from each.
BENCH_ROOMS=torino/hallway-1,muciv/hall

# --- optional ---

# Iterations per starting room. 10 is the sweet spot for stable median/p95.
BENCH_ITERATIONS=10

# Idle time after the loading overlay disappears, before measurement starts.
# Lets the GPU pipeline settle (texture uploads, shader warm-up).
BENCH_WARMUP_SEC=5

# Per-phase durations (seconds).
# ROOM_IDLE: 15 = 900 frames at 60fps → statistically stable p1_low / p5_low / p95.
# Bump to 30+ on AWS for production runs.
BENCH_LOBBY_IDLE_SEC=5
BENCH_ROOM_IDLE_SEC=15
BENCH_POI_OPEN_SEC=8

# Max seconds to wait for a portal transition (portal click → new room loaded).
# If a room is heavy this may need bumping.
BENCH_TRANSITION_TIMEOUT_SEC=60

# Max sweep iterations when searching for POI/portal (walk + rotate + scan cycles).
# Default 20. Bump for open rooms with scattered POIs; lower for tight corridors.
# BENCH_SWEEP_MAX_ATTEMPTS=20

# --- Dry run (smoke test) ---

# Dry-run mode: force 1 iteration per room, record video, write to results-dry-run/
# (separate folder so real metrics aren't polluted). Use to verify a flow works on
# a remote machine after deploy. DO NOT use for benchmark runs — video encoder
# skews FPS by 5-15%, numbers are not comparable to real-mode results.
# BENCH_DRY_RUN=1

# --- Output ---

# BASE directory for results. Each run gets its own timestamped subfolder named
# `<start>__running/` while in progress, renamed to `<start>_to_<end>/` on completion.
# delta.csv is auto-generated comparing the current run vs the most-recent prior
# completed run in this directory (no manual labels needed).
# BENCH_OUTPUT_DIR=./results

# --- GPU validation (pre-flight check before benchmark runs) ---

# Strict: fail if WebGL renderer is not NVIDIA. Recommended on AWS EC2 g4dn.
# BENCH_REQUIRE_NVIDIA=1

# Skip GPU validation entirely. Use only when you knowingly have no usable GPU
# and just want to verify the script logic — numbers will be meaningless.
# BENCH_SKIP_GPU_CHECK=1

# Use the user's installed Chrome (channel: "chrome") instead of Playwright's
# bundled Chromium. Bundled Chromium sometimes has WebGL/GPU quirks (black canvas,
# context lost) that real Chrome doesn't. Try this if the scene renders in regular
# Chrome but not under Playwright. Requires Chrome installed locally / on the EC2.
# BENCH_USE_SYSTEM_CHROME=1
